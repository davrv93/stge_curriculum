  /* SÍLABOS */

  function extractStr(raw, key) {
    const marker = '"' + key + '"';
    let i = raw.indexOf(marker);
    if (i < 0) return '';

    i = raw.indexOf(':', i);
    if (i < 0) return '';

    let s = raw.slice(i + 1).trimStart();
    if (!s.startsWith('"')) return '';

    let out = '';
    let escp = false;

    for (let j = 1; j < s.length; j++) {
      const ch = s[j];

      if (escp) {
        out += ch;
        escp = false;
        continue;
      }

      if (ch === '\\') {
        escp = true;
        continue;
      }

      if (ch === '"') return out;

      out += ch;
    }

    return out;
  }

  function extractStrings(text) {
    const out = [];
    let inside = false;
    let escp = false;
    let cur = '';

    for (let i = 0; i < text.length; i++) {
      const ch = text[i];

      if (!inside) {
        if (ch === '"') {
          inside = true;
          cur = '';
        }
        continue;
      }

      if (escp) {
        cur += ch;
        escp = false;
        continue;
      }

      if (ch === '\\') {
        escp = true;
        continue;
      }

      if (ch === '"') {
        out.push(cur);
        inside = false;
        cur = '';
        continue;
      }

      cur += ch;
    }

    return out;
  }

  function extractArray(raw, key, limit) {
    const marker = '"' + key + '"';
    let i = raw.indexOf(marker);
    if (i < 0) return [];

    i = raw.indexOf('[', i);
    if (i < 0) return [];

    let depth = 0;
    let end = -1;
    let inside = false;
    let escp = false;

    for (let j = i; j < raw.length; j++) {
      const ch = raw[j];

      if (inside) {
        if (escp) escp = false;
        else if (ch === '\\') escp = true;
        else if (ch === '"') inside = false;
        continue;
      }

      if (ch === '"') {
        inside = true;
        continue;
      }

      if (ch === '[') depth++;
      if (ch === ']') {
        depth--;
        if (depth === 0) {
          end = j;
          break;
        }
      }
    }

    const body = end > i ? raw.slice(i + 1, end) : raw.slice(i + 1);
    const arr = extractStrings(body);

    return typeof limit === 'number' ? arr.slice(0, limit) : arr;
  }

  function extractObjArray(raw, key, limit) {
    const marker = '"' + key + '"';
    let i = raw.indexOf(marker);
    if (i < 0) return [];

    i = raw.indexOf('[', i);
    if (i < 0) return [];

    const objs = [];
    let inside = false;
    let escp = false;
    let depth = 0;
    let start = -1;

    for (let j = i + 1; j < raw.length; j++) {
      const ch = raw[j];

      if (inside) {
        if (escp) escp = false;
        else if (ch === '\\') escp = true;
        else if (ch === '"') inside = false;
        continue;
      }

      if (ch === '"') {
        inside = true;
        continue;
      }

      if (ch === '{') {
        if (depth === 0) start = j;
        depth++;
        continue;
      }

      if (ch === '}') {
        depth--;
        if (depth === 0 && start >= 0) {
          objs.push(raw.slice(start, j + 1));
          start = -1;
          if (typeof limit === 'number' && objs.length >= limit) break;
        }
      }

      if (ch === ']' && depth === 0) break;
    }

    return objs;
  }

  function parseSyllabus(raw) {
    const c = clean(raw);
    let txt = c;

    const fenced = c.match(/```json\s*([\s\S]*?)```/i);
    if (fenced) txt = fenced[1];

    const first = txt.indexOf('{');
    const last = txt.lastIndexOf('}');

    if (first >= 0 && last > first) {
      try {
        return JSON.parse(txt.slice(first, last + 1));
      } catch (e) {}
    }

    return {
      sumilla: extractStr(c, 'sumilla'),
      competencia_curso: extractStr(c, 'competencia_curso'),
      resultados_curso: extractArray(c, 'resultados_curso', 6),
      metodologias: extractArray(c, 'metodologias', 6),
      unidades: extractObjArray(c, 'unidades', 6).map((obj, idx) => ({
        unidad: extractStr(obj, 'unidad') || String(idx + 1),
        titulo: extractStr(obj, 'titulo'),
        resultado: extractStr(obj, 'resultado'),
        contenidos: extractArray(obj, 'contenidos', 8),
        producto: extractStr(obj, 'producto')
      })),
      referencias: extractObjArray(c, 'referencias', 8).map(obj => ({
        autor: extractStr(obj, 'autor'),
        anio: extractStr(obj, 'anio') || extractStr(obj, 'fecha'),
        titulo: extractStr(obj, 'titulo') || extractStr(obj, 'nombre'),
        fuente: extractStr(obj, 'fuente') || extractStr(obj, 'editorial'),
        url: extractStr(obj, 'url'),
        utilidad: extractStr(obj, 'utilidad')
      })),
      enlaces: extractObjArray(c, 'enlaces', 8).map(obj => ({
        titulo: extractStr(obj, 'titulo'),
        url: extractStr(obj, 'url'),
        uso: extractStr(obj, 'uso') || extractStr(obj, 'utilidad')
      }))
    };
  }

