    if (!course) {
      toast('El nombre del curso es obligatorio', 'error');
      return;
    }

    const meta = {
      course,
      program: el('s-program') ? el('s-program').value : '',
      credits: el('s-credits') ? el('s-credits').value : '',
      cycle: el('s-cycle') ? el('s-cycle').value : '',
      weeks: el('s-weeks') ? el('s-weeks').value : '16',
      modality: el('s-modal') ? el('s-modal').value : 'Presencial',
      graduate_profile: el('s-profile') ? el('s-profile').value : '',
      competency: el('s-competency') ? el('s-competency').value : '',
      start_date: el('s-start-date') ? el('s-start-date').value : '',
      sessions_per_week: el('s-sessions-per-week') ? el('s-sessions-per-week').value : '1'
    };

    const btn = el('btn-gen-silabo');

    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span> JoMelAi generando sílabo...';
    }

    const host = el('silabo-result');

    if (host) {
      host.style.display = 'block';
      host.innerHTML = `
        <div class="jm-paper-shell">
          <div class="jm-paper">
            <div class="jm-paper-title">
              <small>JoMelAi · Sílabo preliminar</small>
              <h2>Sílabo preliminar: ${esc(course)}</h2>
              <div class="jm-paper-meta">Preparando generación en vivo...</div>
            </div>
            <div class="jm-paper-body"><span class="ai-thinking"><span></span><span></span><span></span></span></div>
          </div>
        </div>
      `;
      host.scrollIntoView({ behavior: 'smooth' });
    }

    let raw = '';
    let config = null;

    try {
      await streamPost('/api/assistant/generate-syllabus-stream', {
        model: MODEL,
        course: meta.course,
        program: meta.program,
        credits: meta.credits,
        cycle: meta.cycle,
        weeks: meta.weeks,
        modality: meta.modality,
        graduate_profile: meta.graduate_profile,
        competency: meta.competency,
        start_date: meta.start_date,
        sessions_per_week: meta.sessions_per_week,
        use_ai_seed: true,
        context_limit: 1,
        ai_timeout: 120
      }, {
        config(data) {
          config = data.tokens_config || config;
        },
        token(data) {
          raw += data.text || '';
          renderSyllabus(raw, meta, config, 'generando...');
        },
        final(data) {
          config = data.tokens_config || config;
          if (!raw && (data.response || data.answer)) raw = data.response || data.answer;
          renderSyllabus(raw, meta, config, '✅ final');
          toast('✅ Sílabo generado', 'success');
        }
      });
    } catch (e) {
      raw += '\n\n⚠️ ' + e.message;
      renderSyllabus(raw, meta, config, 'error');
      toast('Error al generar sílabo: ' + e.message, 'error');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = '🤖 Generar sílabo con JoMelAi';
      }
    }
  }

