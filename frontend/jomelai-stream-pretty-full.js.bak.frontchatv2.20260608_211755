  async function generateResourceStream() {
    css();

    const course = el('r-course') ? el('r-course').value.trim() : '';
    const outcome = el('r-outcome') ? el('r-outcome').value.trim() : '';
    const week = el('r-week') ? el('r-week').value.trim() : '';
    const context = el('r-context') ? el('r-context').value.trim() : '';

    if (!course) {
      toast('Ingresa el nombre del curso', 'error');
      return;
    }

    const type = resType();
    const meta = { type, course, week, outcome, context };
    const btn = el('btn-gen-resource');

    if (btn) {
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner"></span> JoMelAi generando recurso...';
    }

    ensureResourcePaper(meta);

    const host = el('resource-result');
    if (host) host.scrollIntoView({ behavior: 'smooth' });

    S.resource = { raw: '', active: true, continuing: false, config: null, meta };

    let raw = '';
    let config = null;

    const question =
      resPrompt(type) + ' para el curso "' + course + '". ' +
      'Semana/unidad: ' + (week || 'no especificada') + '. ' +
      'Resultado de aprendizaje: "' + (outcome || 'desarrollar competencias del área') + '". ' +
      'Contexto: ' + (context || 'contexto universitario') + '. ' +
      'Genera el recurso completo, estructurado y listo para usar. ' +
      'Incluye título, propósito, instrucciones para el docente, instrucciones para el estudiante, recursos necesarios, secuencia de trabajo, producto esperado, criterios de evaluación, recomendaciones de uso y revisión curricular. ' +
      'Cierra con la línea FIN_DOCUMENTO.';

    try {
      await streamPost('/api/ask-stream', {
        question,
        context: 'resource',
        model: MODEL,
        max_tokens: 1300,
        num_ctx: 1024,
        n_results: 1,
        temperature: 0.22,
        top_p: 0.85
      }, {
        config(data) {
          config = data.tokens_config || config;
          renderResource(raw, config, 'generando...');
        },
        token(data) {
          raw += data.text || '';
          renderResource(raw, config, 'generando...');
        },
        final(data) {
          config = data.tokens_config || config;
          if (!raw && data.answer) raw = data.answer;
          S.resource.active = false;
          renderResource(raw, config, '✅ final');
          toast('✅ Recurso generado', 'success');
        }
      });
    } catch (e) {
      S.resource.active = false;
      renderResource(raw + '\n\n⚠️ ' + e.message, config, 'error');
      toast('Error al generar recurso: ' + e.message, 'error');
    } finally {
      S.resource.active = false;
      updateResourceNotice();
      if (btn) {
        btn.disabled = false;
        btn.innerHTML = '🤖 Generar recurso con JoMelAi';
      }
    }
  }

  async function continueResource() {
    css();

    if (S.resource.active || S.resource.continuing) {
      toast('La generación aún está en proceso. Espere a que finalice antes de continuar.', 'error');
      return;
    }

    const base = clean(S.resource.raw || (el('resource-text') ? el('resource-text').innerText : ''));

    if (!base) {
      toast('No hay contenido previo para continuar.', 'error');
      return;
    }

    if (resourceComplete(base)) {
      updateResourceNotice();
      toast('El recurso ya contiene las secciones esenciales.', 'success');
      return;
    }

    S.resource.continuing = true;
    updateResourceNotice();

    let append = '';
    let config = S.resource.config || null;
    const tail = base.slice(Math.max(0, base.length - 2200));

    const prompt =
      'Continúa un recurso de aprendizaje que quedó incompleto. ' +
      'Devuelve únicamente contenido nuevo que falte después del último fragmento. ' +
      'No repitas título, propósito, instrucciones, recursos, producto, criterios ni recomendaciones que ya estén escritos. ' +
      'Si el documento ya parece completo, responde solamente FIN_DOCUMENTO. ' +
      'Mantén el mismo formato. Cierra con FIN_DOCUMENTO.\n\n' +
      'CONTENIDO YA MOSTRADO:\n' + base + '\n\n' +
      'ÚLTIMO FRAGMENTO:\n' + tail + '\n\n' +
      'CONTINUACIÓN NUEVA:';

    try {
      await streamPost('/api/ask-stream', {
        question: prompt,
        context: 'resource_continue',
        model: MODEL,
        max_tokens: 700,
        num_ctx: 1024,
        n_results: 0,
        temperature: 0.12,
        top_p: 0.85
      }, {
        config(data) {
          config = data.tokens_config || config;
          const da = dedupe(base, append);
          renderResource(base + (da ? '\n\n' + da : ''), config, 'continuando...');
        },
        token(data) {
          append += data.text || '';
          const da = dedupe(base, append);
          renderResource(base + (da ? '\n\n' + da : ''), config, 'continuando...');
        },
        final(data) {
          config = data.tokens_config || config;
          const da = dedupe(base, append || data.answer || '');
          const merged = da ? base + '\n\n' + da : base + '\n\nFIN_DOCUMENTO';
          S.resource.continuing = false;
          renderResource(merged, config, '✅ continuación final');
          toast('Continuación procesada sin duplicar contenido.', 'success');
        }
      });
    } catch (e) {
      toast('Error al continuar: ' + e.message, 'error');
    } finally {
      S.resource.continuing = false;
      updateResourceNotice();
    }
  }

