#!/usr/bin/env bash
set -Eeuo pipefail

PROJECT_DIR="${PROJECT_DIR:-$HOME/jomelai}"

# Modelo SOLO para chat lateral.
# No cambia embeddings, imports, DuckDB, jobs ni otros endpoints.
OLLAMA_IMAGE_VERSION="${OLLAMA_IMAGE_VERSION:-0.5.7}"
LATERAL_PRIMARY_MODEL="${LATERAL_PRIMARY_MODEL:-qwen2.5:0.5b}"
LATERAL_FALLBACK_MODEL="${LATERAL_FALLBACK_MODEL:-tinyllama:latest}"

LATERAL_NUM_CTX="${LATERAL_NUM_CTX:-1024}"
LATERAL_NUM_PREDICT="${LATERAL_NUM_PREDICT:-220}"
LATERAL_TIMEOUT="${LATERAL_TIMEOUT:-90}"
LATERAL_N_RESULTS="${LATERAL_N_RESULTS:-2}"
LATERAL_MAX_CONTEXT_CHARS="${LATERAL_MAX_CONTEXT_CHARS:-2600}"
LATERAL_KEEP_ALIVE="${LATERAL_KEEP_ALIVE:-20m}"

cd "$PROJECT_DIR"

echo "=================================================="
echo " JoMelAi Chat Lateral V2 - Front + Back + Engine"
echo "=================================================="
echo "Proyecto: $PROJECT_DIR"
echo "Ollama image: ollama/ollama:$OLLAMA_IMAGE_VERSION"
echo "Modelo lateral primario: $LATERAL_PRIMARY_MODEL"
echo "Modelo lateral fallback: $LATERAL_FALLBACK_MODEL"

if [ ! -f docker-compose.yml ] && [ ! -f compose.yml ]; then
  echo "ERROR: no encuentro docker-compose.yml ni compose.yml en $PROJECT_DIR"
  exit 1
fi

echo
echo "== 1) Detectando servicios Docker =="
OLLAMA_SERVICE="$(docker compose config --services | grep -i '^ollama$' || true)"
if [ -z "$OLLAMA_SERVICE" ]; then
  OLLAMA_SERVICE="$(docker compose config --services | grep -i 'ollama' | head -1 || true)"
fi

if [ -z "$OLLAMA_SERVICE" ]; then
  echo "ERROR: no encontré servicio Ollama."
  docker compose config --services
  exit 1
fi

DATA_ENGINE_SERVICE="$(docker compose config --services | grep -Ei 'data-engine|data_engine|engine|silabo|api' | head -1 || true)"

echo "Servicio Ollama: $OLLAMA_SERVICE"
echo "Servicio Data Engine candidato: ${DATA_ENGINE_SERVICE:-NO_DETECTADO}"

echo
echo "== 2) Guardando variables .env para chat lateral =="
touch .env

set_env() {
  local key="$1"
  local value="$2"

  if grep -q "^${key}=" .env; then
    sed -i.bak "s|^${key}=.*|${key}=${value}|g" .env
  else
    echo "${key}=${value}" >> .env
  fi
}

set_env "OLLAMA_LATERAL_MODEL" "$LATERAL_PRIMARY_MODEL"
set_env "OLLAMA_LATERAL_FALLBACK_MODEL" "$LATERAL_FALLBACK_MODEL"
set_env "OLLAMA_LATERAL_NUM_CTX" "$LATERAL_NUM_CTX"
set_env "OLLAMA_LATERAL_NUM_PREDICT" "$LATERAL_NUM_PREDICT"
set_env "OLLAMA_LATERAL_TIMEOUT" "$LATERAL_TIMEOUT"
set_env "OLLAMA_LATERAL_N_RESULTS" "$LATERAL_N_RESULTS"
set_env "OLLAMA_LATERAL_MAX_CONTEXT_CHARS" "$LATERAL_MAX_CONTEXT_CHARS"
set_env "OLLAMA_LATERAL_KEEP_ALIVE" "$LATERAL_KEEP_ALIVE"
set_env "DATA_ENGINE_URL" "http://data-engine:8000"

echo
echo "== 3) Fijando versión de Ollama sin tocar data/ollama =="
if [ -f docker-compose.override.yml ]; then
  cp docker-compose.override.yml "docker-compose.override.yml.bak.chatv2.$(date +%Y%m%d_%H%M%S)"
fi

cat > docker-compose.override.yml <<YAML
services:
  $OLLAMA_SERVICE:
    image: ollama/ollama:$OLLAMA_IMAGE_VERSION
    environment:
      OLLAMA_HOST: "0.0.0.0:11434"
      OLLAMA_NUM_PARALLEL: "1"
      OLLAMA_MAX_LOADED_MODELS: "1"
      OLLAMA_KEEP_ALIVE: "$LATERAL_KEEP_ALIVE"
YAML

cat docker-compose.override.yml

echo
echo "== 4) Limpiando capas Docker incompletas, sin borrar volúmenes =="
docker builder prune -af || true
docker image prune -af || true
docker container prune -f || true
sudo apt clean || true

echo
echo "== 5) Levantando Ollama fijo =="
docker compose pull "$OLLAMA_SERVICE"
docker compose up -d --force-recreate "$OLLAMA_SERVICE"

sleep 8

OLLAMA_CONTAINER="$(docker compose ps -q "$OLLAMA_SERVICE")"
if [ -z "$OLLAMA_CONTAINER" ]; then
  echo "ERROR: no pude obtener contenedor Ollama."
  docker compose ps
  exit 1
fi

echo "Contenedor Ollama: $OLLAMA_CONTAINER"
docker exec "$OLLAMA_CONTAINER" ollama --version || true

test_model() {
  local model="$1"

  echo
  echo "== Probando modelo lateral: $model =="
  docker exec "$OLLAMA_CONTAINER" ollama pull "$model"

  set +e
  timeout 90 docker exec "$OLLAMA_CONTAINER" ollama run "$model" "Responde solo: OK"
  local status=$?
  set -e

  if [ "$status" -eq 0 ]; then
    echo "OK: $model funciona."
    return 0
  fi

  echo "FALLÓ: $model"
  docker logs --tail=120 "$OLLAMA_CONTAINER" || true
  return 1
}

FINAL_LATERAL_MODEL=""

if test_model "$LATERAL_PRIMARY_MODEL"; then
  FINAL_LATERAL_MODEL="$LATERAL_PRIMARY_MODEL"
else
  echo
  echo "El modelo primario falló. Probando fallback..."
  if test_model "$LATERAL_FALLBACK_MODEL"; then
    FINAL_LATERAL_MODEL="$LATERAL_FALLBACK_MODEL"
  else
    echo "ERROR: fallaron ambos modelos laterales."
    docker logs --tail=200 "$OLLAMA_CONTAINER" || true
    exit 1
  fi
fi

set_env "OLLAMA_LATERAL_MODEL" "$FINAL_LATERAL_MODEL"

echo
echo "Modelo final para chat lateral: $FINAL_LATERAL_MODEL"

echo
echo "== 6) Detectando archivo Python Data Engine =="
ENGINE_FILE="$(grep -Rsl '@api.post("/rag/answer")' . \
  --exclude-dir=.git \
  --exclude-dir=data \
  --exclude-dir=node_modules \
  --exclude-dir=vendor \
  2>/dev/null | head -1 || true)"

if [ -z "$ENGINE_FILE" ]; then
  echo "ERROR: no encontré el archivo Python con @api.post(\"/rag/answer\")."
  echo "Referencias encontradas:"
  grep -R "rag_answer\|/rag/answer\|FastAPI" -n . \
    --exclude-dir=.git \
    --exclude-dir=data \
    --exclude-dir=node_modules \
    --exclude-dir=vendor \
    2>/dev/null | head -100 || true
  exit 1
fi

echo "Data Engine file: $ENGINE_FILE"
cp "$ENGINE_FILE" "${ENGINE_FILE}.bak.chatv2.$(date +%Y%m%d_%H%M%S)"

echo
echo "== 7) Parcheando Data Engine con APIs nuevas =="
python3 - "$ENGINE_FILE" <<'PY'
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")

# Import StreamingResponse.
if "from fastapi.responses import StreamingResponse" not in text:
    text = text.replace(
        "from fastapi import FastAPI, HTTPException",
        "from fastapi import FastAPI, HTTPException\nfrom fastapi.responses import StreamingResponse"
    )

start = "# === CHAT LATERAL V2 PATCH START ==="
end = "# === CHAT LATERAL V2 PATCH END ==="

patch = r'''
# === CHAT LATERAL V2 PATCH START ===

class ChatLateralAskRequest(BaseModel):
    question: str
    table: str = Field(default=DEFAULT_TABLE)
    collection: str = Field(default="silabos")
    model: Optional[str] = Field(default=None)
    n_results: int = Field(default=2, ge=1, le=5)
    stream: bool = Field(default=False)
