OLLAMA_LATERAL_MODEL = os.getenv("OLLAMA_LATERAL_MODEL", "qwen2.5:0.5b").strip()
OLLAMA_LATERAL_FALLBACK_MODEL = os.getenv("OLLAMA_LATERAL_FALLBACK_MODEL", "tinyllama:latest").strip()
OLLAMA_LATERAL_NUM_CTX = _lat_env_int("OLLAMA_LATERAL_NUM_CTX", 1024)
OLLAMA_LATERAL_NUM_PREDICT = _lat_env_int("OLLAMA_LATERAL_NUM_PREDICT", 220)
OLLAMA_LATERAL_TIMEOUT = _lat_env_int("OLLAMA_LATERAL_TIMEOUT", 90)
OLLAMA_LATERAL_N_RESULTS = _lat_env_int("OLLAMA_LATERAL_N_RESULTS", 2)
OLLAMA_LATERAL_MAX_CONTEXT_CHARS = _lat_env_int("OLLAMA_LATERAL_MAX_CONTEXT_CHARS", 2600)
OLLAMA_LATERAL_KEEP_ALIVE = os.getenv("OLLAMA_LATERAL_KEEP_ALIVE", "20m").strip()
OLLAMA_LATERAL_FORCE_LIGHT = _lat_env_bool("OLLAMA_LATERAL_FORCE_LIGHT", True)


def _lat_jsonable(value: Any) -> Any:
    try:
        json.dumps(value, ensure_ascii=False, default=str)
        return value
    except Exception:
        return json.loads(json.dumps(value, ensure_ascii=False, default=str))


def _lat_sse(event: str, data: Dict[str, Any]) -> str:
    return "event: " + event + "\n" + "data: " + json.dumps(_lat_jsonable(data), ensure_ascii=False) + "\n\n"


def _lat_fast_answer_from_rows(rows: List[Dict[str, Any]], title: str = "Resultado") -> str:
    if not rows:
        return "No encontré registros para esa consulta."

    if len(rows) == 1:
        row = rows[0]
        if "total" in row:
            return f"{title}: {row.get('total')}."
        if "valor" in row:
            return f"{title}: {row.get('valor')}."
        pairs = [f"{k}: {v}" for k, v in row.items()]
        return title + ": " + ", ".join(pairs[:8]) + "."

    return f"{title}: encontré {len(rows)} registros. Revisa la tabla de resultados."


def _lat_compact_sources(results: List[Dict[str, Any]], max_chars: int) -> Tuple[str, List[Dict[str, Any]]]:
    context_parts = []
    evidence = []

    for i, item in enumerate(results[: max(1, OLLAMA_LATERAL_N_RESULTS)]):
        doc = str(item.get("document") or "").strip()
        meta = item.get("metadata") or {}
        if not doc:
            continue

        label = meta.get("curso") or meta.get("programa_estudio") or meta.get("source_file") or f"Fuente {i + 1}"
        context_parts.append(f"[Fuente {i + 1}: {label}]\n{doc}")
        evidence.append(item)

    context = "\n\n".join(context_parts)
    context = context[: max(800, int(max_chars or OLLAMA_LATERAL_MAX_CONTEXT_CHARS))]

    return context, evidence


def _lat_search_rag(question: str, collection: str, n_results: int) -> Dict[str, Any]:
    try:
        return rag_search(RagSearchRequest(
            query=question,
            collection=collection,
            n_results=max(1, min(int(n_results or OLLAMA_LATERAL_N_RESULTS), 5))
        ))
    except Exception as exc:
        return {
            "ok": False,
            "collection": collection,
            "query": question,
            "results": [],
            "count": 0,
            "error": str(exc),
        }


def _lat_generate_once(question: str, context: str, model: Optional[str] = None) -> Dict[str, Any]:
