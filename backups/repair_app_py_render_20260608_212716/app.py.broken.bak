@api.get("/health")
def health() -> Dict[str, Any]:
    ensure_dirs()
    duck_exists = Path(DUCKDB_PATH).exists()
    try:
        ollama = requests.get(f"{OLLAMA_BASE_URL}/api/tags", timeout=5).ok
    except Exception:
        ollama = False
    return {
        "ok": True,
        "service": "upeu-silabo-data-engine",
        "version": "3.0.0",
        "duckdb_path": DUCKDB_PATH,
        "duckdb_exists": duck_exists,
        "chroma_path": CHROMA_PATH,
        "jobs_path": JOBS_PATH,
        "chroma_available": chromadb is not None,
        "ollama_reachable": ollama,
        "embed_model": EMBED_MODEL,
        "max_query_limit": MAX_QUERY_LIMIT,
        "max_chart_rows": MAX_CHART_ROWS,
        "time": time.strftime("%Y-%m-%d %H:%M:%S"),
    }


@api.get("/fs/status")
def fs_status(file_path: str = "/data/syllabi/silabos.csv", collection: str = "silabos") -> Dict[str, Any]:
    ensure_dirs()
    csv = Path(file_path)
    duck = Path(DUCKDB_PATH)
    collection_count = None
    collection_counts: Dict[str, Optional[int]] = {}
    if chromadb is not None:
        try:
            c = chroma_collection(collection)
            collection_count = c.count()
        except Exception:
            collection_count = None
        for cname in ["silabos", "silabos_general", "silabos_competencias", "silabos_sumillas", "silabos_contenidos", "silabos_bibliografia"]:
            try:
                collection_counts[cname] = chroma_collection(cname).count()
            except Exception:
                collection_counts[cname] = None
    return {
        "ok": True,
        "csv": {
            "path": str(csv),
            "exists": csv.is_file(),
            "size_bytes": csv.stat().st_size if csv.is_file() else 0,
            "size_mb": round(csv.stat().st_size / 1024 / 1024, 2) if csv.is_file() else 0,
        },
        "duckdb": {
            "path": str(duck),
            "exists": duck.is_file(),
            "size_bytes": duck.stat().st_size if duck.is_file() else 0,
            "size_mb": round(duck.stat().st_size / 1024 / 1024, 2) if duck.is_file() else 0,
            "tables": list_tables() if duck.is_file() else [],
        },
        "chroma": {
            "path": CHROMA_PATH,
            "available": chromadb is not None,
            "collection": collection,
            "collection_count": collection_count,
            "collection_counts": collection_counts,
        },
    }


@api.get("/fs/syllabi-files")
def syllabi_files() -> Dict[str, Any]:
    base = Path(SYLLABI_PATH)
    base.mkdir(parents=True, exist_ok=True)
    items = []
    for p in sorted(base.glob("*.csv"), key=lambda x: x.stat().st_mtime if x.exists() else 0, reverse=True):
        st = p.stat()
        items.append({
            "name": p.name,
            "path": str(p),
            "size_bytes": st.st_size,
            "size_mb": round(st.st_size / 1024 / 1024, 2),
            "modified_at": time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(st.st_mtime)),
        })
    return {"ok": True, "directory": str(base), "files": items}


